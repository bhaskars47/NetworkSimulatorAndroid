<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ─── Header ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Network Simulator"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.chip.Chip
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inactive"
                android:checkable="false"
                app:chipBackgroundColor="@color/chip_bg_selector"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/chip_text_selector" />
        </LinearLayout>

        <!-- ─── Profile section label ────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Network Profile"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="12dp" />

        <!-- ─── Profile cards row 1 ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSlow3g"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="0dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Slow 3G" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="300 kbps · 300 ms · 1% loss" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHighLatency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="0dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="High Latency" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1000 ms delay · 0.5% loss" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ─── Profile cards row 2 ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPacketLoss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="0dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Packet Loss" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="20% drop · 50 ms delay" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCustom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="0dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Custom" android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Your own parameters" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ─── Profile cards row 3 (Train) ─────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTrain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="0dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Real India"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />
                    <TextView
                        android:id="@+id/tvTrainPhaseChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorPrimary"
                        android:background="@drawable/bg_chip_phase"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:visibility="gone" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Train \u00b7 Lift \u00b7 Stadium \u00b7 Tier-2 \u00b7 Bharat Aunty"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Custom sliders panel ─────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/panelCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Latency" android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <TextView android:id="@+id/labelLatencyValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100 ms" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekLatency" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jitter" android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <TextView android:id="@+id/labelJitterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="± 20 ms" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekJitter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Packet Loss" android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <TextView android:id="@+id/labelLossValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 %" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekLoss" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bandwidth" android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <TextView android:id="@+id/labelBandwidthValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Unlimited" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekBandwidth" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Target app ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target App (package name)"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. com.example.myapp  (blank = all apps)"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTargetPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ─── Toggle button ────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Simulation"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <!-- ─── Live stats strip ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/statsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Phase indicator (Train mode only) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/phaseIndicatorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phase: "
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnPrimaryContainer" />
                    <TextView
                        android:id="@+id/tvPhaseLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnPrimaryContainer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Live numbers row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="10dp"
                style="@style/Widget.Material3.CardView.Filled">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Speed" android:textAppearance="?attr/textAppearanceLabelSmall" android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView android:id="@+id/tvLiveSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— kbps" android:textAppearance="?attr/textAppearanceTitleMedium" android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Latency" android:textAppearance="?attr/textAppearanceLabelSmall" android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView android:id="@+id/tvLiveLatency" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— ms" android:textAppearance="?attr/textAppearanceTitleMedium" android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loss" android:textAppearance="?attr/textAppearanceLabelSmall" android:textColor="?attr/colorOnSurfaceVariant" />
                        <TextView android:id="@+id/tvLiveLoss" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— %" android:textAppearance="?attr/textAppearanceTitleMedium" android:textColor="?attr/colorPrimary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action row: Mark / Export / Clear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkScreen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="📍 Mark Screen"
                    android:enabled="false"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportCsv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="Export CSV"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearLog"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Clear"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <!-- Scrollable log -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Live Log (newest first)"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="4dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStatsLog"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="?attr/colorSurfaceVariant"
                android:clipToPadding="false"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
